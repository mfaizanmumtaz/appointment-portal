    "import http.client\n",
    "\n",
    "conn = http.client.HTTPSConnection(\"api.zoom.us\")\n",
    "\n",
    "headers = { 'Authorization': \"Bearer YOUR_SECRET_TOKEN\" }\n",
    "\n",
    "conn.request(\"POST\", \"/v2/meetings/85746065/open_apps\", headers=headers)\n",
    "\n",
    "res = conn.getresponse()\n",
    "data = res.read()\n",
    "\n",
    "print(data.decode(\"utf-8\"))"
   ]
